{
  "manifest_version": 3,
  "name": "AIMS Helper",
  "version": "6",
  "description": "Autofills CAPTCHA on the login page, shows GPA, gets grades without feedback, submits feedback with one click and can export timetables.",
  "action": {
    "default_title": "AIMS Helper",
    "default_popup": "popup.html"
  },

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://aims.iith.ac.in/*"
  ],

  "background": {
    "service_worker": "grade_fetch_sw.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://aims.iith.ac.in/aims/",
        "https://aims.iith.ac.in/aims/login/loginHome"
      ],
      "js": ["login_captcha_autofill.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://aims.iith.ac.in/aims/courseReg/myCrsHistoryPage*"
      ],
      "js": ["gpa_inject.js", "credits_calculator_launcher.js", "grade_fill.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "gpa_display.js",
        "credits_calculator.html",
        "jspdf.umd.min.js",
        "html2canvas.min.js"],
      "matches": ["https://aims.iith.ac.in/*"]
    }
  ]
}
